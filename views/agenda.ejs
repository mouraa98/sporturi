<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jogos</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
       <!-- Favicon -->
       <link rel="icon" type="image/png" href="/assets/favicon.png">
</head>
<body>
    <header>
        <div class="logo">
            <img src="/assets/logo.png" alt="Logo do Campeonato">
        </div>
        <nav>
            <a href="/" class="admin-button"><i class="fas fa-arrow-left"></i> Voltar</a>
        </nav>
    </header>

    <div class="main-content">
        <div class="container">
            <h1>Jogos</h1>

            <!-- Tabela de jogos agendados -->
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Time 1</th>
                            <th>Time 2</th>
                            <th>Data</th>
                            <th>Hora</th>
                            <th>Local</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (agenda && agenda.length > 0) { %>
                            <% agenda.forEach((jogo) => { %>
                                <tr>
                                    <td><img src="<%= jogo.logo1 %>" alt="Logo do Time 1" style="height: 30px;"> <%= jogo.time1 %></td>
                                    <td><img src="<%= jogo.logo2 %>" alt="Logo do Time 2" style="height: 30px;"> <%= jogo.time2 %></td>
                                    <td><%= jogo.data %></td>
                                    <td><%= jogo.hora %></td>
                                    <td><%= jogo.local %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5">Nenhum jogo agendado.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <footer>
        <p>&copy; 2025 Tabela de Campeonatos. Todos os direitos reservados.</p>
    </footer>
</body>
</html>